terraform {
  backend "s3" {
    region  = "us-east-1"
    encrypt = true
    # bucket and key are passed dynamically via -backend-config in the CI/CD pipeline
  }

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
    local = {
      source  = "hashicorp/local"
      version = "~> 2.5"
    }
  }
}

provider "aws" {
  region = var.aws_region
}
